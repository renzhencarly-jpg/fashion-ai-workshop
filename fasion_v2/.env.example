# =============================================================================
# Fashion AI Workshop — environment template
# Copy this file to ".env" and fill in the values:
#     cp .env.example .env
# Never commit your real .env (it is gitignored).
# =============================================================================

# --- MongoDB Atlas (YOU create this) -----------------------------------------
# Your own Atlas M0 free-cluster connection string.
# Atlas → Connect → Drivers → copy the mongodb+srv URI, and put your DB
# username/password into it.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/
DB_NAME=fashion_db

# --- Voyage AI (YOU register) ------------------------------------------------
# Free key from https://www.voyageai.com  (used for embeddings + reranking)
VOYAGE_API_KEY=<your-voyage-api-key>

# --- Azure OpenAI (PROVIDED BY THE INSTRUCTOR) -------------------------------
# The instructor will give you these 2 values during the workshop.
# Used for search query understanding + post-purchase preference extraction.
AZURE_OPENAI_API_KEY=<provided-by-instructor>
AZURE_OPENAI_ENDPOINT=<provided-by-instructor>

# --- Optional (defaults are fine) --------------------------------------------
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# VOYAGE_EMBED_MODEL=voyage-3.5
# VOYAGE_RERANK_MODEL=rerank-2
# VECTOR_INDEX=vector_index
# TEXT_INDEX=default
# PORT=7861
